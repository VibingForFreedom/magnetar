# Magnetar Configuration
# Copy this file to .env and adjust values as needed

# Database Configuration
# DB_TYPE: sqlite or mariadb
#DB_TYPE=sqlite

# SQLite Settings (used when DB_TYPE=sqlite)
#DB_PATH=./data/magnetar.db

# MariaDB/MySQL Settings (used when DB_TYPE=mariadb)
#DB_HOST=localhost
#DB_PORT=3306
#DB_NAME=magnetar
#DB_USER=magnetar
#DB_PASSWORD=

# Crawler Configuration
# User agent string for HTTP requests
#CRAWLER_USER_AGENT=Magnetar/0.1.0

# Request timeout in seconds
#CRAWLER_TIMEOUT=30

# Maximum concurrent requests
#CRAWLER_MAX_CONCURRENT=10

# Rate limit: requests per second per domain
#CRAWLER_RATE_LIMIT=2

# Maximum retries for failed requests
#CRAWLER_MAX_RETRIES=3

# Delay between retries in seconds
#CRAWLER_RETRY_DELAY=5

# Respect robots.txt (true/false)
#CRAWLER_RESPECT_ROBOTS=true

# Classification Settings
# Minimum confidence threshold for classification (0.0-1.0)
#CLASSIFY_MIN_CONFIDENCE=0.7

# Batch size for classification processing
#CLASSIFY_BATCH_SIZE=100

# Matching Settings
# Fuzzy match threshold (0.0-1.0)
#MATCHER_FUZZY_THRESHOLD=0.85

# Maximum results to return per match query
#MATCHER_MAX_RESULTS=50

# API Server Configuration
# API listen address
#API_HOST=0.0.0.0
#API_PORT=8080

# Enable API authentication
#API_AUTH_ENABLED=false

# API key for authentication (if enabled)
#API_KEY=

# CORS allowed origins (comma-separated)
#API_CORS_ORIGINS=*

# Rate limiting: requests per minute per IP
#API_RATE_LIMIT=60

# Compression Settings
# Compression algorithm: zstd, gzip, none
#COMPRESS_ALGORITHM=zstd

# Compression level (1-22 for zstd, 1-9 for gzip)
#COMPRESS_LEVEL=3

# Importer Settings
# Supported formats: csv, json, ndjson
#IMPORTER_BATCH_SIZE=1000

# Skip duplicates during import
#IMPORTER_SKIP_DUPLICATES=true

# Logging
# Log level: debug, info, warn, error
#LOG_LEVEL=info

# Log format: json, text
#LOG_FORMAT=json

# General Settings
# Environment: development, staging, production
#ENV=development
