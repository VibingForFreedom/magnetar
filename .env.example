# Magnetar Configuration
# Copy this file to .env and adjust values as needed
# All variables use the MAGNETAR_ prefix

# ── Server ───────────────────────────────────────────────
#MAGNETAR_PORT=3333
#MAGNETAR_API_KEY=
#MAGNETAR_LOG_LEVEL=info

# ── Database ─────────────────────────────────────────────
# Backend: "sqlite" or "mariadb"
#MAGNETAR_DB_BACKEND=sqlite

# SQLite settings
#MAGNETAR_DB_PATH=data/magnetar.db
#MAGNETAR_DB_CACHE_SIZE=65536
#MAGNETAR_DB_MMAP_SIZE=268435456
#MAGNETAR_DB_SYNC_FULL=false

# MariaDB settings (required when DB_BACKEND=mariadb)
#MAGNETAR_DB_DSN=user:pass@tcp(localhost:3306)/magnetar
#MAGNETAR_DB_MAX_OPEN_CONNS=25
#MAGNETAR_DB_MAX_IDLE_CONNS=10

# ── DHT Crawler ──────────────────────────────────────────
#MAGNETAR_CRAWL_ENABLED=true
#MAGNETAR_CRAWL_RATE=1000
#MAGNETAR_CRAWL_WORKERS=4
#MAGNETAR_CRAWL_PORT=6881

# ── Metadata Matching ────────────────────────────────────
#MAGNETAR_MATCH_ENABLED=true
#MAGNETAR_MATCH_BATCH_SIZE=100
#MAGNETAR_MATCH_INTERVAL=10s
#MAGNETAR_MATCH_MAX_ATTEMPTS=4
#MAGNETAR_TMDB_API_KEY=
#MAGNETAR_TVDB_API_KEY=

# ── Tracker Scraping ─────────────────────────────────────
#MAGNETAR_TRACKER_ENABLED=false
#MAGNETAR_TRACKER_LIST=
#MAGNETAR_TRACKER_TIMEOUT=5s

# ── Valkey (Redis-compatible cache) ──────────────────────
#MAGNETAR_VALKEY_URL=

# ── Anime DB ─────────────────────────────────────────────
#MAGNETAR_ANIMEDB_ENABLED=true

# ── Backup ───────────────────────────────────────────────
#MAGNETAR_BACKUP_ENABLED=false
#MAGNETAR_BACKUP_PATH=/data/backups
#MAGNETAR_BACKUP_SCHEDULE=0 3 * * *
#MAGNETAR_BACKUP_RETAIN=7

# ── Maintenance ──────────────────────────────────────────
#MAGNETAR_ANALYZE_INTERVAL=50000
#MAGNETAR_INTEGRITY_CHECK_DAILY=true
